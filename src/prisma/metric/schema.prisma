generator client {
  provider = "prisma-client-js"
  output   = "../../src/prisma/metric"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_METRICAS")
}

model ai_doc {
  id                  Int       @id @default(autoincrement())
  docente_id          Int
  asignatura_id       Int
  tiempo_id           Int
  aspecto_id          Int
  conclusion          String?   @db.Text
  conclusion_general  String?   @db.Text
  fortalezas          Json?
  debilidades         Json?
  fecha_actualizacion DateTime? @default(now()) @db.Timestamp(0)
  doc                 doc       @relation(fields: [docente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ai_doc_ibfk_1")
  asig                asig      @relation(fields: [asignatura_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ai_doc_ibfk_2")
  tmp                 tmp       @relation(fields: [tiempo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ai_doc_ibfk_3")
  asp_cfg             asp_cfg   @relation(fields: [aspecto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ai_doc_ibfk_4")

  @@index([asignatura_id], map: "asignatura_id")
  @@index([aspecto_id], map: "aspecto_id")
  @@index([docente_id], map: "docente_id")
  @@index([tiempo_id], map: "tiempo_id")
}

model asig {
  id                Int            @id @default(autoincrement())
  cod_asignatura    String         @unique(map: "cod_asignatura") @db.VarChar(10)
  nombre_asignatura String?        @db.VarChar(100)
  fecha_creacion    DateTime?      @default(now()) @db.Timestamp(0)
  ai_doc            ai_doc[]
  eval_doc          eval_doc[]
  eval_doc_asp      eval_doc_asp[]
  part              part[]
}

model asp_cfg {
  id             Int            @id @default(autoincrement())
  cfg_id         Int
  cfg_a_id       Int
  aspecto_id     Int
  nombre         String         @db.VarChar(100)
  descripcion    String?        @db.Text
  orden          Decimal?       @db.Decimal(5, 2)
  fecha_creacion DateTime?      @default(now()) @db.Timestamp(0)
  ai_doc         ai_doc[]
  eval_doc_asp   eval_doc_asp[]
}

model ctx {
  id             Int        @id @default(autoincrement())
  id_cfg         Int?
  id_sed         Int?
  id_per         Int?
  id_prog        Int?
  id_sem         Int?
  id_grup        Int?
  fecha_creacion DateTime?  @default(now()) @db.Timestamp(0)
  sed            sed?       @relation(fields: [id_sed], references: [id_sede], onDelete: NoAction, onUpdate: NoAction, map: "ctx_ibfk_1")
  per            per?       @relation(fields: [id_per], references: [id_periodo], onDelete: NoAction, onUpdate: NoAction, map: "ctx_ibfk_2")
  prog           prog?      @relation(fields: [id_prog], references: [id_prog], onDelete: NoAction, onUpdate: NoAction, map: "ctx_ibfk_3")
  sem            sem?       @relation(fields: [id_sem], references: [id_sem], onDelete: NoAction, onUpdate: NoAction, map: "ctx_ibfk_4")
  grup           grup?      @relation(fields: [id_grup], references: [id_grupo], onDelete: NoAction, onUpdate: NoAction, map: "ctx_ibfk_5")
  eval_doc       eval_doc[]
  met_eval       met_eval[]
  part           part[]

  @@index([id_grup], map: "id_grup")
  @@index([id_per], map: "id_per")
  @@index([id_prog], map: "id_prog")
  @@index([id_sed], map: "id_sed")
  @@index([id_sem], map: "id_sem")
}

model doc {
  id                Int            @id @default(autoincrement())
  documento_docente String         @unique(map: "documento_docente") @db.VarChar(15)
  nombre_docente    String?        @db.VarChar(203)
  fecha_creacion    DateTime?      @default(now()) @db.Timestamp(0)
  ai_doc            ai_doc[]
  eval_doc          eval_doc[]
  eval_doc_asp      eval_doc_asp[]
  part              part[]
  rank_doc          rank_doc[]
}

model est {
  id                   Int       @id @default(autoincrement())
  documento_estudiante String    @unique(map: "documento_estudiante") @db.VarChar(20)
  primer_nombre        String?   @db.VarChar(50)
  segundo_nombre       String?   @db.VarChar(50)
  primer_apellido      String?   @db.VarChar(50)
  segundo_apellido     String?   @db.VarChar(50)
  fecha_creacion       DateTime? @default(now()) @db.Timestamp(0)
  part                 part[]
}

model eval_doc {
  id                      Int       @id @default(autoincrement())
  docente_id              Int?
  asignatura_id           Int?
  contexto_academico_id   Int?
  tiempo_id               Int?
  promedio_general        Decimal?  @default(0.00) @db.Decimal(5, 2)
  desviacion_general      Decimal?  @default(0.00) @db.Decimal(5, 2)
  total_evaluaciones      Int?      @default(0)
  total_realizadas        Int?      @default(0)
  total_pendientes        Int?      @default(0)
  total_aspectos          Int?      @default(0)
  porcentaje_cumplimiento Decimal?  @default(0.00) @db.Decimal(5, 2)
  suma                    Int?      @default(0)
  fecha_creacion          DateTime? @default(now()) @db.Timestamp(0)
  doc                     doc?      @relation(fields: [docente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_ibfk_1")
  asig                    asig?     @relation(fields: [asignatura_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_ibfk_2")
  ctx                     ctx?      @relation(fields: [contexto_academico_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_ibfk_3")
  tmp                     tmp?      @relation(fields: [tiempo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_ibfk_4")

  @@index([asignatura_id], map: "asignatura_id")
  @@index([contexto_academico_id], map: "contexto_academico_id")
  @@index([docente_id], map: "docente_id")
  @@index([tiempo_id], map: "tiempo_id")
}

model eval_doc_asp {
  id               Int       @id @default(autoincrement())
  docente_id       Int
  asignatura_id    Int
  tiempo_id        Int
  aspecto_id       Int
  suma             Int?      @default(0)
  promedio         Decimal?  @db.Decimal(5, 2)
  desviacion       Decimal?  @db.Decimal(5, 2)
  total_respuestas Int?      @default(0)
  fecha_creacion   DateTime? @default(now()) @db.Timestamp(0)
  doc              doc       @relation(fields: [docente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_asp_ibfk_1")
  asig             asig      @relation(fields: [asignatura_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_asp_ibfk_2")
  tmp              tmp       @relation(fields: [tiempo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_asp_ibfk_3")
  asp_cfg          asp_cfg   @relation(fields: [aspecto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "eval_doc_asp_ibfk_4")

  @@index([asignatura_id], map: "asignatura_id")
  @@index([aspecto_id], map: "aspecto_id")
  @@index([docente_id], map: "docente_id")
  @@index([tiempo_id], map: "tiempo_id")
}

model grup {
  id_grupo Int    @id @default(autoincrement())
  nombre   String @unique(map: "nombre") @db.VarChar(50)
  ctx      ctx[]
}

model met_eval {
  id                             Int       @id @default(autoincrement())
  contexto_academico_id          Int?
  tiempo_id                      Int?
  total_evaluaciones             Int?      @default(0)
  total_realizadas               Int?      @default(0)
  total_evaluaciones_registradas Int?      @default(0)
  total_pendientes               Int?      @default(0)
  total_estudiantes              Int?      @default(0)
  total_estudiantes_registrados  Int?      @default(0)
  total_estudiantes_pendientes   Int?      @default(0)
  total_docentes                 Int?      @default(0)
  total_docentes_pendientes      Int?      @default(0)
  fecha_creacion                 DateTime? @default(now()) @db.Timestamp(0)
  ctx                            ctx?      @relation(fields: [contexto_academico_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "met_eval_ibfk_1")
  tmp                            tmp?      @relation(fields: [tiempo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "met_eval_ibfk_2")

  @@index([contexto_academico_id], map: "contexto_academico_id")
  @@index([tiempo_id], map: "tiempo_id")
}

model part {
  id                    Int                     @id @default(autoincrement())
  estudiante_id         Int?
  docente_id            Int?
  asignatura_id         Int?
  contexto_academico_id Int?
  tiempo_id             Int?
  estado_evaluacion     part_estado_evaluacion? @default(PENDIENTE)
  fecha_evaluacion      DateTime?               @db.Date
  fecha_creacion        DateTime?               @default(now()) @db.Timestamp(0)
  est                   est?                    @relation(fields: [estudiante_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "part_ibfk_1")
  doc                   doc?                    @relation(fields: [docente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "part_ibfk_2")
  asig                  asig?                   @relation(fields: [asignatura_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "part_ibfk_3")
  ctx                   ctx?                    @relation(fields: [contexto_academico_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "part_ibfk_4")
  tmp                   tmp?                    @relation(fields: [tiempo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "part_ibfk_5")

  @@index([asignatura_id], map: "asignatura_id")
  @@index([contexto_academico_id], map: "contexto_academico_id")
  @@index([docente_id], map: "docente_id")
  @@index([estudiante_id], map: "estudiante_id")
  @@index([tiempo_id], map: "tiempo_id")
}

model per {
  id_periodo Int    @id @default(autoincrement())
  nombre     String @unique(map: "nombre") @db.VarChar(50)
  ctx        ctx[]
}

model prog {
  id_prog Int    @id @default(autoincrement())
  nombre  String @unique(map: "nombre") @db.VarChar(250)
  ctx     ctx[]
}

model rank_doc {
  id                            Int       @id @default(autoincrement())
  docente_id                    Int?
  total_evaluaciones            Int?      @default(0)
  total_evaluaciones_realizadas Int?      @default(0)
  promedio_general              Decimal?  @default(0.00) @db.Decimal(5, 2)
  total_aspectos_evaluados      Int?      @default(0)
  porcentaje_cumplimiento       Decimal?  @default(0.00) @db.Decimal(5, 2)
  ranking                       Int?      @default(0)
  fecha_actualizacion           DateTime? @default(now()) @db.Timestamp(0)
  doc                           doc?      @relation(fields: [docente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rank_doc_ibfk_1")

  @@index([docente_id], map: "docente_id")
}

model sed {
  id_sede Int    @id @default(autoincrement())
  nombre  String @unique(map: "nombre") @db.VarChar(50)
  ctx     ctx[]
}

model sem {
  id_sem Int    @id @default(autoincrement())
  nombre String @unique(map: "nombre") @db.VarChar(50)
  ctx    ctx[]
}

model tmp {
  id             Int            @id @default(autoincrement())
  anio           Int?
  mes            Int?
  dia            Int?
  semana         Int?
  trimestre      Int?
  fecha          DateTime?      @db.Date
  fecha_creacion DateTime?      @default(now()) @db.Timestamp(0)
  ai_doc         ai_doc[]
  eval_doc       eval_doc[]
  eval_doc_asp   eval_doc_asp[]
  met_eval       met_eval[]
  part           part[]
}

enum part_estado_evaluacion {
  PENDIENTE
  COMPLETA
}
